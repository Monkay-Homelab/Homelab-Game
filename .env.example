# Variables interpolated by docker-compose.yml.
# Copy to .env (next to docker-compose.yml) and fill in real values.
# Both files live at the repo root; only .env is gitignored.

# ---- Database / Auth ----

# PostgreSQL password for the homelab_game user.
# The db service initializes with this on first run; do NOT change after the
# pgdata volume has data — the existing data still expects the original.
DB_PASSWORD=

# JWT signing secret for backend auth tokens.
# Generate with: openssl rand -hex 32
JWT_SECRET=

# ---- Public URLs ----
# Set these to whatever clients use to reach the deployment: a domain
# (https://api.example.com), a LAN IP (http://192.168.1.10:8085), or an
# mDNS hostname (http://homelab.lan:8085).
# The compose host ports are 8085 (backend) and 8086 (frontend) by default.

# Public URL of the backend API. The frontend container's entrypoint bakes
# this into window.__APP_CONFIG__.API_URL at startup, so the browser knows
# where to call. Required for any non-default deployment.
# Examples:
#   https://api.example.com
#   http://192.168.1.10:8085
#   http://homelab.lan:8085
API_URL=

# Comma-separated CORS allowlist for the backend (frontend origins). This is
# additive — the backend's built-in homelab.living origins remain allowed.
# The browser must call API_URL from one of these origins.
# Examples:
#   https://game.example.com
#   http://192.168.1.10:8086
#   http://192.168.1.10:8086,https://game.example.com
CORS_ORIGINS=
