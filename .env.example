# Variables interpolated by docker-compose.yml.
# Copy this file to .env (next to docker-compose.yml) and fill in real values.
# Both .env and .env.example are at the repo root; only .env is gitignored.

# PostgreSQL password for the homelab_game user.
# The db service initializes with this on first run; do not change after the
# volume has data — the existing pgdata still expects the original password.
DB_PASSWORD=

# JWT signing secret for backend auth tokens.
# Generate with: openssl rand -hex 32
JWT_SECRET=
