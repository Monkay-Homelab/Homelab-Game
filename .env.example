# Variables interpolated by docker-compose.yml.
# Copy to .env (next to docker-compose.yml) and fill in real values.
# Both files live at the repo root; only .env is gitignored.
#
# This template is pre-filled for a LAN deployment at 192.168.2.100. Adjust the
# IP if yours is different, or replace with a domain for public deploys.

# ---- Database / Auth ----

# PostgreSQL password for the homelab_game user.
# The db service initializes with this on first run; do NOT change after the
# pgdata volume has data — the existing data still expects the original.
# Generate with: openssl rand -hex 24
DB_PASSWORD=

# JWT signing secret for backend auth tokens.
# Generate with: openssl rand -hex 32
JWT_SECRET=

# ---- Public URLs ----
# Compose host ports default to 8085 (backend) and 8086 (frontend).

# Public URL of the backend API. Used as the fallback when API_URL_MAP doesn't
# have an entry for the current browser hostname.
# Examples:
#   http://192.168.2.100:8085         (LAN, IP-based)
#   http://homelab.lan:8085           (LAN with mDNS hostname)
#   https://api.example.com           (public with TLS terminated upstream)
API_URL=http://192.168.2.100:8085

# Serve LAN and public clients from the same deployment by mapping each
# frontend hostname to its matching backend URL. The frontend reads
# window.location.hostname at load time and picks the entry that matches.
# Format: host1=url1,host2=url2,*=fallback (comma-separated). The optional
# `*=fallback` handles any hostname not in the list; if omitted, the
# resolver falls through to API_URL above.
API_URL_MAP=192.168.2.100=http://192.168.2.100:8085,game.homelab.living=https://api.homelab.living,dev-game.homelab.living=https://dev-api.homelab.living,*=https://api.homelab.living

# Comma-separated CORS allowlist for the backend (frontend origins). This is
# additive — the backend's built-in homelab.living origins remain allowed.
# List every frontend origin you want to permit; the browser must call
# API_URL from one of these origins.
CORS_ORIGINS=http://192.168.2.100:8086,https://game.homelab.living,https://dev-game.homelab.living
